{
  "$schema":    "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default M4TR1X capabilities — works on all platforms",
  "platforms":  ["linux", "macOS", "windows", "android", "iOS"],
  "windows":    ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "http:default",
    "http:allow-fetch",
    "os:default",
    "os:allow-platform",
    "os:allow-version",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
